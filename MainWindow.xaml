<Window x:Class="esprogrammazioneasincrona.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:esprogrammazioneasincrona"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" VerticalAlignment="Top">
            <TextBlock Text="Lettera estratta:" Margin="0,0,0,5" />
            <Label x:Name="lblLettere" Content="" FontSize="30" FontWeight="Bold" Margin="0,0,0,20" />

            <TextBlock Text="Parola:" Margin="0,0,0,5" />
            <Label x:Name="lblParole" Content="" FontSize="18" Margin="0,0,0,20" />

            <Button x:Name="btnLettera" Content="Clicca qui" Click="btnLettera_Click" Height="40" />
        </StackPanel>

        <StackPanel Grid.Column="1" Margin="20,0,0,0">
            <TextBlock Text="Storico parole:" Margin="0,0,0,5" />
            <ListBox x:Name="listaParole" Height="180" />
        </StackPanel>

    </Grid>
</Window>
